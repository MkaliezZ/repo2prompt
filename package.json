{
  "name": "repo2prompt",
  "version": "0.1.1",
  "description": "Turn any codebase into an AI-ready context pack for Claude Code, Codex, Cursor, Cline, Gemini CLI, and other AI coding agents.",
  "type": "module",
  "bin": {
    "repo2prompt": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "ai",
    "ai-agents",
    "agent-context",
    "cli",
    "context",
    "codebase",
    "repo",
    "repository",
    "prompt",
    "codex",
    "claude",
    "cursor",
    "cline",
    "gemini",
    "copilot"
  ],
  "author": "MkaliezZ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MkaliezZ/repo2prompt.git"
  },
  "bugs": {
    "url": "https://github.com/MkaliezZ/repo2prompt/issues"
  },
  "homepage": "https://github.com/MkaliezZ/repo2prompt#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
